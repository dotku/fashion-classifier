# OpenRouter API key (required) - https://openrouter.ai/
# Used for classification models, text embeddings, reranking, and translation
OPENROUTER_API_KEY=

# Gemini API key (optional) - https://aistudio.google.com/apikey
# For Gemini 2.5 Flash classification (free tier, default model)
GEMINI_API_KEY=

# Pexels API key (optional) - https://www.pexels.com/api/
# Only needed for downloading eval images
PEXELS_API_KEY=
